# Copy this file to local.properties and update paths for your machine
# local.properties is gitignored and machine-specific

sdk.dir=/Users/YOUR_USERNAME/Library/Android/sdk
flutter.sdk=/Users/YOUR_USERNAME/development/flutter
flutter.buildMode=debug
flutter.versionName=2.0.0
flutter.versionCode=1

# On Windows, paths look like:
# sdk.dir=C\:\\Users\\YOUR_USERNAME\\AppData\\Local\\Android\\Sdk
# flutter.sdk=C\:\\src\\flutter

# On Linux:
# sdk.dir=/home/YOUR_USERNAME/Android/Sdk
# flutter.sdk=/home/YOUR_USERNAME/development/flutter
