# ============================================================
# AGENT PRO GHANA — Environment Variables
# Copy to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# App
NODE_ENV=development
PORT=3000
APP_NAME=Agent Pro Ghana
APP_URL=https://api.agentproghana.com
ADMIN_URL=https://admin.agentproghana.com
FRONTEND_URL=https://agentproghana.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/agentpro_ghana
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_URL=redis://username:password@host:6379

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-64-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_ROUNDS=12

# Anthropic Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Firebase (FCM Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@agentproghana.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Agent Pro Ghana <noreply@agentproghana.com>"

# Superuser (created on first run)
SUPERUSER_EMAIL=admin@agentproghana.com
SUPERUSER_PASSWORD=change-this-immediately
SUPERUSER_FIRST_NAME=Agent Pro
SUPERUSER_LAST_NAME=Admin

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Agent Pro Ghana MoMo Merchant
MOMO_MERCHANT_NUMBER=your-mtn-momo-number
MOMO_MERCHANT_NAME=Agent Pro Ghana

# Encryption (for sensitive local data)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
